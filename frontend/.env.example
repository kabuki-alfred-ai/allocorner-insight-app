# ──────────────────────────────────────────────────────────────────────────────
# Frontend — variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ──────────────────────────────────────────────────────────────────────────────

# URL du backend proxié par Vite (ne pas toucher sauf cas particulier)
# Le proxy Vite redirige /api → VITE_BACKEND_URL
# Développement local  → http://localhost:3000
# Backend en prod      → https://allocorner.kabukimono.tech
VITE_BACKEND_URL=http://localhost:3000
